# Copy this file to .env before running locally.
# Windows PowerShell:
# Copy-Item .env.example .env
# Windows CMD:
# copy .env.example .env

APP_NAME=hotel_management
APP_ENV=local
SERVER_PORT=8080

# Database (MySQL)
DB_URL=jdbc:mysql://localhost:3306/hotel_management?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=Jefino@1537

# Optional JWT settings (needed only when JWT auth is implemented)
JWT_SECRET=local_dev_jwt_secret_change_me_12345
JWT_EXPIRATION_MS=3600000

# Local dev admin seeding (runs only when APP_ENV=local)
# Creates/promotes this user to ADMIN on application startup.
APP_DEV_ADMIN_EMAIL=admin@example.com
APP_DEV_ADMIN_PASSWORD=ChangeMe@12345
APP_DEV_ADMIN_NAME=Local Admin
